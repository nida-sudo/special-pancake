# Copy this file to `.env` for local runs. .env is gitignored.
# In CI, configure these values as GitHub Actions Secrets — not in the repo.

# Gmail SMTP (use a 16-char App Password, NOT your regular Gmail password)
SMTP_USER=nida33854@gmail.com
SMTP_PASS=replace-with-gmail-app-password

# Where the run report goes
MAIL_TO=nida@ruh.ai,aakash@ruh.ai

# Test account that drives the Ruh app
